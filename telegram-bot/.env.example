# GaeDHD Telegram bot config. Copy to .env and fill in.
# The .env lives on the QNAP and is NOT overwritten by deploy.sh (rsync excludes it).

# --- Required ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_botfather_token   # HTTP API token from @BotFather
GAEDHD_NOW_TOKEN=change-me-same-as-vercel                 # shared device/bot secret; must match Vercel's GAEDHD_NOW_TOKEN
ALLOWED_CHAT_IDS=1948731399,987654321                     # comma-separated chat IDs allowed to use the bot (John's + hers)

# --- Photo reading / conversational capture (required for those features) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx                         # from console.anthropic.com; without it, text is dumb-captured and photos are refused

# --- App base URL (optional) ---
GAEDHD_BASE_URL=https://gaedhd.jmj.fyi                    # optional; defaults to https://gaedhd.jmj.fyi

# --- Gentle ritual nudges (optional) ---
NUDGES_ENABLED=false                                      # set "true" to enable the every-30-min ritual nudge loop
NUDGE_CHAT_ID=987654321                                   # her chat ID; required when NUDGES_ENABLED=true
QUIET_START=21                                            # hour (0-23) quiet hours begin; default 21
QUIET_END=8                                               # hour (0-23) quiet hours end; default 8

# --- Daily morning planning prompt (optional) ---
MORNING_PROMPT_ENABLED=false                             # set "true" to send the once-a-day "what are you trying to do today?" prompt
MORNING_HOUR=9                                            # hour (0-23) the morning prompt fires; default 9
MORNING_CHAT_ID=987654321                                # who gets the morning prompt; defaults to NUDGE_CHAT_ID if unset

# --- Body-doubling (optional) ---
JOHN_CHAT_ID=1948731399                                   # John's chat ID; /focus pings him to body-double. Optional — /focus works without it

# --- Timezone (optional) ---
TZ=America/Los_Angeles                                    # container clock; drives quiet hours + morning prompt + event times. Set in docker-compose too
