# GaeDHD presence bridge config. Copy to .env and fill in.
# The .env lives on the QNAP and is NOT overwritten by deploy.sh (rsync excludes it).

# --- Required ---
GAEDHD_NOW_TOKEN=change-me-same-as-vercel     # shared device/bot secret; must match Vercel's GAEDHD_NOW_TOKEN
MQTT_PASS=your-mosquitto-password             # broker password; the bridge warns and fails to connect without it

# --- MQTT broker (optional; defaults shown) ---
MQTT_HOST=192.168.87.100                      # QNAP/broker LAN IP; default 192.168.87.100
MQTT_PORT=1883                                # broker port; default 1883
MQTT_USER=gaedhd                              # broker username; default "gaedhd" (NOTE: AMBIENT-SETUP.md's examples use "mqtt")

# --- Beacon (optional; defaults shown) ---
DEVICE_ID=gaes_beacon                         # the aliased beacon to follow; default "gaes_beacon" (NOTE: AMBIENT-SETUP.md aliases it "her_beacon")

# --- App base URL (optional) ---
GAEDHD_BASE_URL=https://gaedhd.jmj.fyi        # optional; defaults to https://gaedhd.jmj.fyi

# --- Nearest-room tuning (optional; defaults shown) ---
FRESH_MS=30000                                # a room reading older than this (ms) is ignored; default 30000
DWELL_MS=8000                                 # a new room must stay nearest this long (ms) before switching; default 8000
TICK_MS=3000                                  # how often (ms) nearest-room is recomputed; default 3000
MAX_DISTANCE_M=8                              # readings farther than this (m) don't count as "in the room"; default 8

# --- Presence keep-alive (optional; defaults shown) ---
KEEPALIVE_MS=600000                           # re-affirm current room this often (ms) so presence doesn't age out; default 600000 (10 min)
ACTIVE_START=7                                # hour (0-23) keep-alive starts; default 7
ACTIVE_END=22                                 # hour (0-23) keep-alive ends; default 22

# --- Timezone (optional) ---
TZ=America/Los_Angeles                        # container clock; drives inActiveHours() for keep-alive. Set in docker-compose too
